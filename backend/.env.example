# Put your Alchemy (or Infura) URL here. Prefer a WebSocket URL for best realtime behavior if available
ALCHEMY_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY_HERE
# Path to service account JSON inside backend folder
FIREBASE_SERVICE_ACCOUNT=firebase-auth.json
# Topic name used for FCM notifications (clients should subscribe)
FIREBASE_TOPIC=usdt-large-transfers
# HTTP port for backend (used for /subscribe endpoint)
PORT=3000
